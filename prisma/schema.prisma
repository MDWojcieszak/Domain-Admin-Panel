generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum AccountStatus {
  CREATED
  EMAIL_VERIFICATION
  ACTIVE
  DISABLED
}

enum SocialMediaType {
  FACEBOOK
  INSTAGRAM
  TWITTER
  TIKTOK
  LINKEDIN
  GITHUB
}

enum FileType {
  IMAGE
  PDF
  AUDIO
  VIDEO
  OTHER
}

enum ServerProcessStatus {
  UNKNOWN
  STARTED
  ONGOING
  CLOSED
  ENDED
  FAILED
}

enum ServerStatus {
  UNKNOWN
  OFFLINE
  ONLINE
  ERROR
  MAINTENANCE
  WAKE_IN_PROGRESS
  SHUTDOWN_IN_PROGRESS
}

enum CommandType {
  MESSAGE
  EVENT
}

enum CommandStatus {
  ENABLED
  DISABLED
  RUNNING
}

enum CommandRuntimeStatus {
  IDLE
  STARTING
  RUNNING
  STOPPING
  STOPPED
  ERROR
}

enum CommandMatchType {
  CONTAINS
  STARTS_WITH
  REGEX
}

enum ProcessLogLevel {
  LOG
  SUCCESS
  WARNING
  ERROR
}

enum SettingType {
  STRING
  NUMBER
}

enum DiskType {
  HDD
  SSD
  NVME
}

enum TaskType {
  TODO
  TAKE_ITEM
  CONVERSATION
  NOTE
  EVENT
  HABIT
  REMINDER
  AUTOMATION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DEFERRED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum CollaboratorRole {
  OWNER
  COLLABORATOR
  OBSERVER
}

enum ConnectedServiceType {
  GOOGLE
  TODOIST
  NOTION
  TELEGRAM
  N8N
  OPENAI
  OTHER
  IMMICH
}

enum PlaceType {
  HOME
  WORK
  FAMILY_HOME
  FRIEND_HOME
  RESTAURANT
  SHOP
  OFFICE
  SCHOOL
  GYM
  HOSPITAL
  HOTEL
  HOSTEL
  AIRPORT
  TRAIN_STATION
  BUS_STATION
  PORT
  PARK
  BEACH
  MOUNTAIN
  CAMP
  NATIONAL_PARK
  MUSEUM
  MONUMENT
  ATTRACTION
  TRAVEL_DESTINATION
  SIGHTSEEING
  EVENT
  OTHER
}

enum PlaceMemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum PersonRelation {
  FAMILY
  FRIEND
  WORK
  OTHER
}

enum ApiKeyType {
  AI
  INTERNAL
  EXTERNAL
}

enum ServerTransferMode {
  MOVE
  COPY
}

enum ServerTransferStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

enum CategorySource {
  AGENT
  MAIN
}

enum PhotoEntryType {
  GENERAL
  WORK
  ASTRO
}

enum PhotoEntryStatus {
  PLANNED
  ACTIVE
  SELECTED
  EDITING
  COMPLETED
}

enum MediaStatus {
  UPLOADED
  NOT_UPLOADED
}

model User {
  id           String  @id @default(uuid())
  role         Role    @default(USER)
  email        String  @unique
  hashPassword String?

  accountStatus AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  firstName     String?
  lastName      String?

  sessions        Session[]
  authorOfImages  ImageData[]   @relation("author")
  creatorOfImages ImageData[]   @relation("creator")
  socialMedia     SocialMedia[]

  avatar         Image?             @relation("UserAvatar", fields: [avatarId], references: [id])
  avatarId       String?            @unique
  uploadedImages Image[]            @relation("ImageUploader")
  serverSessions Process[]
  startedServers ServerProperties[] @relation("StartedBy")
  stoppedServers ServerProperties[] @relation("StoppedBy")
  userSettings   UserSettings?

  photoEntries PhotoEntry[]

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?

  // Assistant relations
  personalTasks     Task[]
  persons           Person[]
  places            Place[]
  tags              Tag[]
  taskCustomFields  TaskCustomField[]
  taskComments      TaskComment[]
  taskActivities    TaskActivity[]
  achievements      Achievement[]
  taskCollaborators TaskCollaborator[]
  notifications     NotificationLog[]
  attachments       Attachment[]

  apiKeys           ApiKey[]
  connectedServices ConnectedService[]
  createdLocations  Location[]
  placeMember       PlaceMember[]

  permissionGroups PermissionGroup[] @relation("UserPermissionGroups")

  createdPosts          BlogPost[]
  blogAuthorships       BlogPostAuthor[]
  blogLikes             BlogPostLike[]
  blogViews             BlogPostView[]
  blogFeedback          BlogPostFeedback[]
  blogEditorialComments BlogEditorialComment[]
  accessGrants          AccessGrant[]
  appDevices            AppDevice[]
  redeemedCodes         RedeemCode[]
  blogMediaAlbums       BlogMediaAlbum[]
}

model PermissionGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[]
  users       User[]   @relation("UserPermissionGroups")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Person {
  id          String          @id @default(uuid())
  name        String
  nickname    String?
  email       String?
  phone       String?
  notes       String?
  birthday    DateTime?
  socialMedia SocialMedia[]
  avatarUrl   String?
  relation    PersonRelation?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  tasks Task[] @relation("PersonTasks")

  @@index([userId])
}

model Task {
  id              String       @id @default(uuid())
  description     String
  type            TaskType     @default(TODO)
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  dueDate         DateTime?
  repeat          RepeatType   @default(NONE)
  repeatCustom    String?
  estimatedTime   Int?
  actualTime      Int?
  energyLevel     String?
  moodRequired    String?
  calendarEventId String?
  notes           String?
  isTemplate      Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  completedAt     DateTime?
  archived        Boolean      @default(false)
  score           Int          @default(0)
  reward          String?
  reminderAt      DateTime?
  isPrivate       Boolean      @default(false)

  aiSuggestions   Json?
  aiSummary       String?
  integrationMeta Json?
  syncStatus      String?
  externalSyncId  String?
  requiresApiKey  Boolean               @default(false)
  requiredService ConnectedServiceType?

  // Relations

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  placeId String?
  place   Place?  @relation(fields: [placeId], references: [id])

  personId String?
  person   Person? @relation("PersonTasks", fields: [personId], references: [id])

  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id], map: "fk_task_parentTaskId")
  subtasks     Task[]  @relation("Subtasks")

  blocks    TaskBlock[] @relation("Blocks")
  blockedBy TaskBlock[] @relation("BlockedBy")

  attachments   Attachment[]
  comments      TaskComment[]
  tags          TaskTag[]
  activities    TaskActivity[]
  checklist     TaskChecklistItem[]
  collaborators TaskCollaborator[]
  customFields  TaskCustomField[]
  achievements  Achievement[]
  notifications NotificationLog[]
}

model TaskBlock {
  blockerId String
  blockedId String

  blocker Task @relation("Blocks", fields: [blockerId], references: [id])
  blocked Task @relation("BlockedBy", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}

model Place {
  id          String     @id @default(uuid())
  name        String
  description String?
  type        PlaceType?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  tasks   Task[]
  members PlaceMember[]

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?

  @@index([ownerId])
}

model PlaceMember {
  id String @id @default(uuid())

  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  placeId String

  joinedAt DateTime         @default(now())
  role     PlaceMemberRole? @default(MEMBER)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([placeId, userId])
}

model Location {
  id          String   @id @default(uuid())
  name        String?
  address     String?
  city        String?
  postalCode  String?
  country     String?
  latitude    Float?
  longitude   Float?
  radius      Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdById String?

  Place Place[]
}

model TaskChecklistItem {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  content   String
  done      Boolean  @default(false)
  order     Int?
  createdAt DateTime @default(now())
}

model TaskCustomField {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  name      String
  value     String
  type      String?
  order     Int?
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Tag {
  id     String    @id @default(uuid())
  name   String
  color  String?
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  tasks  TaskTag[]
}

model TaskTag {
  id     String @id @default(uuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String
}

model TaskActivity {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  timestamp DateTime @default(now())
  details   String?
}

model TaskComment {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  comment   String
  createdAt DateTime @default(now())
}

model Attachment {
  id           String   @id @default(uuid())
  fileUrl      String
  fileType     FileType
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  uploadedById String
  createdAt    DateTime @default(now())

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?
}

model Achievement {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  description String?
  achievedAt  DateTime @default(now())
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id])

  aiContext   AiContext? @relation(fields: [aiContextId], references: [id])
  aiContextId String?
}

model TaskCollaborator {
  id        String           @id @default(uuid())
  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      CollaboratorRole @default(COLLABORATOR)
  createdAt DateTime         @default(now())
}

model NotificationLog {
  id     String    @id @default(uuid())
  task   Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String?
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  type   String
  status String
  sentAt DateTime  @default(now())
  meta   Json?
  readAt DateTime?
}

model ApiKey {
  id        String               @id @default(uuid())
  user      User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  name      String?
  value     String
  service   ConnectedServiceType
  type      ApiKeyType
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  expiresAt DateTime?
  meta      Json?

  @@unique([userId, service, type])
  @@index([type])
}

model AiContext {
  id           String   @id @default(uuid())
  summary      String?
  keywords     Json?
  context      String?
  aiMeta       Json?
  aiConfidence Float?
  aiSource     String?
  aiHistory    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  achievement Achievement[]
  attachment  Attachment[]
  task        Task[]
  place       Place[]
  person      Person[]
  user        User[]
  history     AiHistory[]
}

model AiHistory {
  id          String    @id @default(uuid())
  aiContext   AiContext @relation(fields: [aiContextId], references: [id], onDelete: Cascade)
  aiContextId String

  timestamp  DateTime @default(now())
  action     String
  source     String?
  userPrompt String?
  aiResponse String?
  text       String?
  meta       Json?
}

model ConnectedService {
  id           String               @id @default(uuid())
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  type         ConnectedServiceType
  displayName  String?
  accessToken  String?
  refreshToken String?
  meta         Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  // AI context fields
  summary      String?
  keywords     Json?
  context      String?
  aiMeta       Json?
  aiConfidence Float?
  aiSource     String?
  aiHistory    Json?
}

model UserSettings {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  serverStatusEmailNotifications Boolean @default(true)
  serverIdleEmailNotifications   Boolean @default(false)
  serverPushNotifications        Boolean @default(false)
  processEmailNotifications      Boolean @default(true)
  processPushNotifications       Boolean @default(false)
}

model SocialMedia {
  id       String          @id @default(uuid())
  username String
  link     String
  type     SocialMediaType
  user     User?           @relation(fields: [userId], references: [id])
  userId   String?
  person   Person?         @relation(fields: [personId], references: [id])
  personId String?
}

model Session {
  id           String  @id
  platform     String?
  browser      String?
  os           String?
  refreshToken String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model ImageData {
  id           String   @id @default(uuid())
  localization String
  dateTaken    DateTime

  title       String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User    @relation(fields: [createdById], references: [id], name: "creator")
  createdById String
  author      User?   @relation(fields: [authorId], references: [id], name: "author")
  authorId    String?

  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId String @unique
}

enum ImageScope {
  GALLERY
  BLOG
}

model Image {
  id           String      @id @default(uuid())
  originalUrl  String
  coverUrl     String
  lowResUrl    String
  data         ImageData?
  dimensions   Dimensions? @relation(fields: [dimensionsId], references: [id], onDelete: Cascade)
  dimensionsId String?     @unique
  avatar       User?       @relation("UserAvatar")

  // Hard partition between the owner's personal gallery and blog media.
  scope        ImageScope @default(GALLERY)
  uploadedBy   User?      @relation("ImageUploader", fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt    DateTime   @default(now())

  blogVersionCovers   BlogPostVersion[]    @relation("VersionCover")
  blogVersionOgImages BlogPostVersion[]    @relation("VersionOgImage")
  blogSectionImages   BlogSectionImage[]
  poiCovers           Poi[]                @relation("PoiCover")
  poiImages           PoiImage[]
  poiCollectionCovers PoiCollection[]
  blogSeriesCovers    BlogSeries[]
  homeBlockImages     HomeBlock[]
  blogAlbumItems      BlogMediaAlbumItem[]
  blogAlbumCovers     BlogMediaAlbum[]     @relation("BlogAlbumCover")

  @@index([scope])
}

model Dimensions {
  id     String @id @default(uuid())
  width  String
  height String
  image  Image?
}

/// Reusable blog photo set ("zbiór fotek"). Groups BLOG-scoped images for reuse
/// across posts; kept separate from the owner's personal gallery.
model BlogMediaAlbum {
  id          String  @id @default(uuid())
  name        String
  description String?

  coverImage   Image?  @relation("BlogAlbumCover", fields: [coverImageId], references: [id])
  coverImageId String?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BlogMediaAlbumItem[]

  @@index([createdById])
}

model BlogMediaAlbumItem {
  id      String         @id @default(uuid())
  album   BlogMediaAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumId String
  image   Image          @relation(fields: [imageId], references: [id]) // app-enforced scope=BLOG
  imageId String
  order   Int            @default(0)

  createdAt DateTime @default(now())

  @@unique([albumId, imageId])
  @@index([albumId, order])
}

model Server {
  id   String @id @default(uuid())
  name String @unique

  ipAddress  String
  macAddress String?
  location   String?
  isDeleted  Boolean @default(false)

  queueName String @unique

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  properties ServerProperties?
  categories ServerCategory[]
}

model ServerCategory {
  id       String @id @default(uuid())
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId String

  name  String?
  value String

  source CategorySource @default(AGENT)

  commands        ServerCommand[]
  settings        ServerSettings[]
  processes       Process[]
  serverTransfers ServerTransfer[]

  @@unique([serverId, value])
}

model ServerCommand {
  id               String         @id @default(uuid())
  serverCategory   ServerCategory @relation(fields: [serverCategoryId], references: [id], onDelete: Cascade)
  serverCategoryId String
  name             String?
  value            String
  status           CommandStatus  @default(DISABLED)
  type             CommandType

  progressMarkers CommandProgressMarker[]
  processes       Process[]
}

model CommandProgressMarker {
  id        String        @id @default(uuid())
  command   ServerCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)
  commandId String

  label         String?
  pattern       String
  matchType     CommandMatchType      @default(CONTAINS)
  progress      Int?
  runtimeStatus CommandRuntimeStatus?
  level         ProcessLogLevel?
  order         Int                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([commandId])
}

model ServerSettings {
  id               String         @id @default(uuid())
  serverCategory   ServerCategory @relation(fields: [serverCategoryId], references: [id], onDelete: Cascade)
  serverCategoryId String
  name             String?
  serverName       String
  value            String
  type             SettingType
}

model ServerProperties {
  id       String @id @default(uuid())
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId String @unique

  status     ServerStatus?
  lastSeenAt DateTime?
  isOnline   Boolean       @default(false)

  startedBy   User?     @relation("StartedBy", fields: [startedById], references: [id], onDelete: NoAction)
  startedById String?
  startedAt   DateTime?

  stoppedBy   User?     @relation("StoppedBy", fields: [stoppedById], references: [id], onDelete: NoAction)
  stoppedById String?
  stoppedAt   DateTime?

  cpuInfo    CPUInfo?
  memoryInfo MemoryInfo?

  uptime BigInt?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  cPUInfoId    String?
  memoryInfoId String?
  diskInfo     DiskInfo[]
}

model CPUInfo {
  id                 String           @id @default(uuid())
  cores              Int?
  physicalCores      Int?
  currentLoad        Float?
  currentLoadUser    Float?
  currentLoadSystem  Float?
  ServerProperties   ServerProperties @relation(fields: [serverPropertiesId], references: [id], onDelete: Cascade)
  serverPropertiesId String           @unique
}

model MemoryInfo {
  id                 String           @id @default(uuid())
  total              BigInt?
  free               BigInt?
  ServerProperties   ServerProperties @relation(fields: [serverPropertiesId], references: [id], onDelete: Cascade)
  serverPropertiesId String           @unique
}

model DiskInfo {
  id                 String           @id @default(uuid())
  fs                 String?
  type               String?
  used               BigInt?
  available          BigInt?
  name               String?
  mediaType          DiskType?
  ServerProperties   ServerProperties @relation(fields: [serverPropertiesId], references: [id], onDelete: Cascade)
  serverPropertiesId String
}

model Process {
  id        String    @id @default(uuid())
  startedAt DateTime  @default(now())
  stoppedAt DateTime?
  name      String

  startedBy   User   @relation(fields: [startedById], references: [id])
  startedById String

  category   ServerCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction)
  categoryId String?

  command   ServerCommand? @relation(fields: [commandId], references: [id], onDelete: NoAction)
  commandId String?

  status          ServerProcessStatus
  runtimeStatus   CommandRuntimeStatus @default(IDLE)
  progress        Int?                 @default(0)
  logs            ProcessLog[]
  serverTransfers ServerTransfer[]
}

model ProcessLog {
  id        String           @id @default(uuid())
  message   String
  timestamp DateTime         @default(now())
  level     ProcessLogLevel? @default(LOG)
  process   Process          @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId String
}

model ServerTransfer {
  id String @id @default(uuid())

  serverCategoryId String
  serverCategory   ServerCategory @relation(fields: [serverCategoryId], references: [id], onDelete: Cascade)

  name        String
  description String?

  originPath   String
  targetPath   String
  agentLogPath String?

  enableMoveBackup Boolean @default(false)
  moveBackupPath   String?

  mode   ServerTransferMode   @default(COPY)
  status ServerTransferStatus @default(IDLE)

  bwLimitKbps  Int?
  secondsStart Int
  secondsStop  Int
  isEnabled    Boolean @default(true)

  queuedFiles BigInt @default(0)
  queuedBytes BigInt @default(0)
  sentFiles   BigInt @default(0)
  sentBytes   BigInt @default(0)

  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  currentProcess   Process? @relation(fields: [currentProcessId], references: [id])
  currentProcessId String?

  @@unique([serverCategoryId, name])
  @@index([serverCategoryId])
}

model AstroObject {
  id   String  @id @default(uuid())
  name String
  code String?

  thumbnailUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photoLinks PhotoEntryAstroObject[]
}

model PhotoEntry {
  id     String           @id @default(uuid())
  name   String
  type   PhotoEntryType   @default(GENERAL)
  status PhotoEntryStatus @default(PLANNED)

  startDate DateTime?
  endDate   DateTime?

  rootPath         String?
  foldersCreated   Boolean   @default(false)
  foldersCreatedAt DateTime?

  uploadStatus MediaStatus @default(NOT_UPLOADED)

  astroObjects PhotoEntryAstroObject[]
  immichAlbum  PhotoEntryImmichAlbum?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, type])
  @@index([userId, startDate])
  @@index([userId, status])
}

model PhotoEntryAstroObject {
  id String @id @default(uuid())

  photoEntry   PhotoEntry @relation(fields: [photoEntryId], references: [id], onDelete: Cascade)
  photoEntryId String

  astroObject   AstroObject @relation(fields: [astroObjectId], references: [id], onDelete: Cascade)
  astroObjectId String

  rootPath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([photoEntryId, astroObjectId])
  @@unique([photoEntryId, rootPath])
  @@index([astroObjectId])
}

model PhotoEntryImmichAlbum {
  id String @id @default(uuid())

  photoEntry   PhotoEntry @relation(fields: [photoEntryId], references: [id], onDelete: Cascade)
  photoEntryId String     @unique

  albumId   String
  albumName String

  sourcePaths Json?

  lastSyncedAt   DateTime?
  lastAssetCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([albumId])
}

// ============================================================
// BLOG / CMS
// ============================================================

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// Rola w byline: autorzy i współautorzy (oba mnogie)
enum BlogAuthorRole {
  AUTHOR
  CO_AUTHOR
}

// Oś dostępu czytelnika (NIE ACL personelu). PUBLIC < REGISTERED < PREMIUM.
enum BlogAccessTier {
  PUBLIC
  REGISTERED
  PREMIUM
}

enum VersionState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogSectionType {
  HEADING
  PARAGRAPH
  QUOTE
  CALLOUT
  LIST
  IMAGE
  GALLERY
  MAP
  PLACE
  EMBED
  DIVIDER
  COLUMNS // kontener layoutu kolumn (nestuje COLUMN)
  COLUMN // pojedyncza kolumna (nestuje bloki-liście)
}

// Feedback czytelnika „czy post przydatny?".
enum BlogFeedbackRating {
  HELPFUL
  NOT_HELPFUL
}

enum CalloutVariant {
  INFO
  TIP
  WARNING
  SUCCESS
}

enum EmbedProvider {
  YOUTUBE
  VIMEO
  SPOTIFY
  X
  OTHER
}

enum GalleryLayout {
  GRID
  CAROUSEL
  MASONRY
  FULLWIDTH
}

// Prezentacja zdjęcia per-użycie (NIE px — semantyczny rozmiar; FE renderuje responsywnie).
enum BlogImageSize {
  SMALL
  MEDIUM
  LARGE
  FULL
  FULL_BLEED
}

// Proporcje kadru (otypowane; FE mapuje na realny stosunek). ORIGINAL = naturalne proporcje zdjęcia.
enum BlogAspectRatio {
  ORIGINAL
  SQUARE // 1:1
  RATIO_4_3 // poziome
  RATIO_3_2 // poziome (klasyka aparatu)
  RATIO_16_9 // poziome (szerokie)
  RATIO_21_9 // panorama / kino
  RATIO_65_24 // panoramiczne (ultra-szerokie)
  RATIO_3_4 // pionowe
  RATIO_2_3 // pionowe
  RATIO_4_5 // pionowe (social)
  RATIO_9_16 // pionowe (story)
}

// Pozycja tekstu na zdjęciu — siatka 9-punktowa.
enum BlogOverlayPosition {
  TOP_LEFT
  TOP_CENTER
  TOP_RIGHT
  MIDDLE_LEFT
  MIDDLE_CENTER
  MIDDLE_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
  BOTTOM_RIGHT
}

// Kolor/kontrast tekstu overlay.
enum BlogOverlayTheme {
  LIGHT
  DARK
}

// Tło pod tekstem na zdjęciu dla czytelności.
enum BlogOverlayBackdrop {
  NONE // sam tekst (z cieniem)
  SCRIM // przyciemniona warstwa
  GRADIENT // gradient od krawędzi
  GLASS // efekt szkła (frosted/glassmorphism)
}

enum CategoryKind {
  POST
  ATTRACTION
}

// POI (wspólna encja podróżnicza blog ↔ apka-planer)
enum PoiPriceLevel {
  FREE
  LOW
  MODERATE
  HIGH
}

enum PoiSeason {
  SPRING
  SUMMER
  AUTUMN
  WINTER
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

// Trudność trasy/aktywności (trekkingi, podejścia górskie)
enum PoiDifficulty {
  EASY
  MODERATE
  HARD
  EXPERT
}

// Wewnętrzna ocena twórców „czy nam się podobało" (prywatna, do planowania tras — NIE publiczna)
enum PoiVerdict {
  LOVED
  LIKED
  MIXED
  DISLIKED
  SKIP // nie warto / pomijamy w trasach
}

enum PoiStatus {
  ACTIVE
  TEMPORARILY_CLOSED
  PERMANENTLY_CLOSED
}

// Źródło przyznania dostępu: zakup apki / subskrypcja → tier dostępu (paywall bloga)
enum AccessGrantSource {
  APP_PURCHASE
  SUBSCRIPTION
  MANUAL
  REDEEM_CODE
}

enum AppPlatform {
  IOS
  ANDROID
}

enum HomeBlockType {
  HERO
  FEATURED_POSTS
  CATEGORY_ROW
  POST_GRID
  MAP
  TEXT
}

model BlogPost {
  id              String         @id @default(uuid())
  slug            String         @unique
  status          BlogPostStatus @default(DRAFT)
  accessTier      BlogAccessTier @default(PUBLIC) // bramka całego posta (globalna, nie wersjonowana)
  order           Int?
  viewCount       Int            @default(0)
  likeCount       Int            @default(0)
  helpfulCount    Int            @default(0)
  notHelpfulCount Int            @default(0)

  // kto utworzył wpis (system/owner, do „moich postów"); byline (autorzy + współautorzy) w `authors`
  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  series      BlogSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  seriesId    String?
  seriesOrder Int? // pozycja w serii (cz. 1/2/3)

  firstPublishedAt DateTime?
  lastPublishedAt  DateTime?
  scheduledFor     DateTime?
  archivedAt       DateTime? // „usuń post" = archiwizacja (soft, odzyskiwalne); brak twardego purge

  // draft = aktualnie edytowana, published = widoczna publicznie.
  // hasUnpublishedChanges = draftVersionId !== publishedVersionId
  draftVersion       BlogPostVersion? @relation("DraftVersion", fields: [draftVersionId], references: [id])
  draftVersionId     String?          @unique
  publishedVersion   BlogPostVersion? @relation("PublishedVersion", fields: [publishedVersionId], references: [id])
  publishedVersionId String?          @unique

  versions          BlogPostVersion[]      @relation("AllVersions")
  authors           BlogPostAuthor[]
  likes             BlogPostLike[]
  views             BlogPostView[]
  feedback          BlogPostFeedback[]
  homeBlockPosts    HomeBlockPost[]
  editorialComments BlogEditorialComment[]
  searchDocuments   BlogSearchDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, firstPublishedAt])
  @@index([status, scheduledFor]) // cron publikujący zaplanowane
  @@index([createdById]) // „moje posty"
  @@index([order])
}

model BlogPostVersion {
  id            String       @id @default(uuid())
  post          BlogPost     @relation("AllVersions", fields: [postId], references: [id], onDelete: Cascade)
  postId        String
  versionNumber Int
  state         VersionState @default(DRAFT)

  // treść TEKSTOWA (title/subtitle/excerpt/seoKeywords/meta/reading) → BlogPostVersionTranslation (per locale)
  coverImage   Image?  @relation("VersionCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  coverImageId String?
  ogImage      Image?  @relation("VersionOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
  ogImageId    String? // obraz do social share (og:image); językowo-neutralny domyślny

  country String? // canonical, językowo-neutralne (filtr listy)
  region  String?

  translations BlogPostVersionTranslation[]
  sections     BlogSection[]
  categories   BlogVersionCategory[]

  publishedAt DateTime?
  archivedAt  DateTime? // gdy stara PUBLISHED → ARCHIVED przy republikacji; tylko ARCHIVED można prune'ować
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  draftOfPost     BlogPost? @relation("DraftVersion")
  publishedOfPost BlogPost? @relation("PublishedVersion")

  @@unique([postId, versionNumber])
  @@index([postId, state])
}

model BlogSection {
  id        String          @id @default(uuid())
  version   BlogPostVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId String
  type      BlogSectionType
  order     Int

  // bramka per-sekcja: teaser PUBLIC + reszta REGISTERED/PREMIUM
  minAccessTier BlogAccessTier @default(PUBLIC)

  // treść TEKSTOWA (title/body-markdown/keywords) → BlogSectionTranslation (per locale)

  // scalary per-typ (single-table inheritance) — językowo-neutralne (layout)
  headingLevel   Int?
  quoteAuthor    String? // nazwa autora cytatu (proper noun, wspólna)
  calloutVariant CalloutVariant?
  galleryLayout  GalleryLayout?
  embedUrl       String?
  embedProvider  EmbedProvider?

  // Layout kolumn (1 poziom): COLUMNS → COLUMN(columnWidth) → bloki-liście.
  parent      BlogSection?  @relation("SectionChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  children    BlogSection[] @relation("SectionChildren")
  columnWidth Float? // udział kolumny, 0..1 (względny; front normalizuje)

  translations BlogSectionTranslation[]
  images       BlogSectionImage[]
  items        BlogSectionListItem[]
  pois         SectionPoi[]

  editorialComments BlogEditorialComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([versionId, order])
  @@index([parentId, order])
}

model BlogSectionImage {
  id        String      @id @default(uuid())
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  image     Image       @relation(fields: [imageId], references: [id])
  imageId   String
  order     Int         @default(0)

  // tekst (caption/alt/overlayText) → BlogSectionImageTranslation (per locale)

  // --- prezentacja (deklaratywna intencja; FE renderuje, brak px w bazie) ---
  size        BlogImageSize   @default(LARGE)
  aspectRatio BlogAspectRatio @default(ORIGINAL)
  focalX      Float? // 0..1 punkt ostrości do responsywnego kadru; null = środek
  focalY      Float?

  // --- układ tekstu na zdjęciu (sam tekst w tłumaczeniach) ---
  overlayPosition BlogOverlayPosition?
  overlayTheme    BlogOverlayTheme? // kolor tekstu: jasny/ciemny
  overlayBackdrop BlogOverlayBackdrop? // tło pod tekstem (m.in. GLASS)

  translations BlogSectionImageTranslation[]

  @@unique([sectionId, imageId])
  @@index([sectionId, order])
}

model BlogSectionListItem {
  id        String      @id @default(uuid())
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  order     Int         @default(0)

  // treść (content) → BlogSectionListItemTranslation (per locale)
  translations BlogSectionListItemTranslation[]

  @@index([sectionId, order])
}

model SectionPoi {
  id        String      @id @default(uuid())
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  poi       Poi         @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId     String
  order     Int         @default(0)

  @@unique([sectionId, poiId])
}

// Point of Interest — WSPÓŁDZIELONA encja podróżnicza (seam blog ↔ apka-planer).
// Blog: sekcje wskazują POI; apka: buduje z nich trasy/dni. Tekst (name override/description) w PoiTranslation.
model Poi {
  id        String  @id @default(uuid())
  name      String // canonical / identyfikator (proper noun, np. "Skógafoss")
  country   String?
  region    String?
  city      String?
  address   String?
  latitude  Float
  longitude Float
  timezone  String? // IANA, np. "Atlantic/Reykjavik" — apka „otwarte teraz?" wg strefy miejsca

  // Nawigacja działa po latitude/longitude (uniwersalne deep-linki: Apple/Google/Waze
  // budowane app-side wg preferencji usera). Poniższe ID = TYLKO opcjonalne wzbogacenie/dedup,
  // NIE mechanizm otwierania map. Apple nie ma publicznego place-id, stąd brak appleMapsId.
  googlePlaceId String? @unique
  osmId         String?

  // atrybuty podróżnicze (apka-planer)
  visitDurationMin Int? // sugerowany czas na miejscu (min)
  creatorRating    Int? // 1–5: jak bardzo „warto zobaczyć" (publiczna waga dla AI przy doborze tras)
  creatorVerdict   PoiVerdict? // WEWNĘTRZNA ocena „czy nam się podobało" (prywatna, planowanie)
  internalNote     String? // WEWNĘTRZNA notatka twórców (prywatna, NIE publiczna)
  priceLevel       PoiPriceLevel?
  bestSeasons      PoiSeason[]
  websiteUrl       String?
  bookingUrl       String?
  mapsUrl          String?

  // dla tras/aktywności (trasa górska itp.); null = zwykły punkt
  difficulty     PoiDifficulty?
  distanceKm     Float?
  elevationGainM Int?

  status PoiStatus @default(ACTIVE) // ACTIVE / TEMPORARILY_CLOSED / PERMANENTLY_CLOSED

  coverImage   Image?  @relation("PoiCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  coverImageId String?

  // localized name override + description → PoiTranslation (per locale)
  translations PoiTranslation[]
  hours        PoiHours[]
  images       PoiImage[] // galeria zdjęć miejsca (uporządkowana)
  categories   PoiCategory[] // wiele kategorii (wodospad + punkt widokowy)
  collections  PoiCollectionItem[] // rankowane listy „top miejsc"
  sections     SectionPoi[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PoiCategory {
  id         String   @id @default(uuid())
  poi        Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId      String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@unique([poiId, categoryId])
  @@index([categoryId])
}

model PoiImage {
  id      String @id @default(uuid())
  poi     Poi    @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId   String
  image   Image  @relation(fields: [imageId], references: [id])
  imageId String
  order   Int    @default(0)

  @@unique([poiId, imageId])
  @@index([poiId, order])
}

model PoiHours {
  id       String  @id @default(uuid())
  poi      Poi     @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId    String
  weekday  Weekday
  opensAt  String? // "HH:mm"
  closesAt String? // "HH:mm"
  closed   Boolean @default(false)

  @@unique([poiId, weekday])
}

model Category {
  id       String       @id @default(uuid())
  kind     CategoryKind
  key      String // canonical, np. "food", "waterfall"
  icon     String?
  color    String?
  isSystem Boolean      @default(false)
  order    Int?

  // label → CategoryTranslation (per locale)
  translations CategoryTranslation[]
  posts        BlogVersionCategory[]
  pois         PoiCategory[]
  blocks       HomeBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, key])
}

model BlogVersionCategory {
  id         String          @id @default(uuid())
  version    BlogPostVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId  String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@unique([versionId, categoryId])
  @@index([categoryId]) // filtr „posty w kategorii X"
}

model BlogPostLike {
  id        String   @id @default(uuid())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model BlogPostView {
  id        String   @id @default(uuid())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model HomeLayout {
  id       String      @id @default(uuid())
  name     String
  isActive Boolean     @default(false)
  blocks   HomeBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeBlock {
  id       String        @id @default(uuid())
  layout   HomeLayout    @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  layoutId String
  type     HomeBlockType
  order    Int

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?
  image      Image?    @relation(fields: [imageId], references: [id], onDelete: SetNull)
  imageId    String?
  limit      Int?

  // title/body → HomeBlockTranslation (per locale)
  translations HomeBlockTranslation[]
  posts        HomeBlockPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([layoutId, order])
}

model HomeBlockPost {
  id      String    @id @default(uuid())
  block   HomeBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId String
  post    BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId  String
  order   Int       @default(0)

  @@unique([blockId, postId])
}

// Wewnętrzne komentarze redakcyjne (jak piny w Figmie). Nigdy widoczne publicznie.
// Kotwica: post (sectionId = null → wątek ogólny) lub sekcja + opcjonalny fragment tekstu.
model BlogEditorialComment {
  id     String   @id @default(uuid())
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  section     BlogSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId   String?
  anchorStart Int?
  anchorEnd   Int?
  quote       String?

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
  body     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([sectionId])
}

// Feedback czytelnika na końcu posta („czy przydatny?"). Agregat widoczny po stronie admina.
model BlogPostFeedback {
  id      String             @id @default(uuid())
  post    BlogPost           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId  String
  user    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId  String?
  rating  BlogFeedbackRating
  comment String? // opcjonalny krótki komentarz

  createdAt DateTime @default(now())

  @@unique([postId, userId]) // jeden feedback per zalogowany user (NULL = anonim, wiele)
  @@index([postId, rating])
}

// ============================================================
// I18N — rejestr języków + tabele tłumaczeń (per pole, wspólna struktura)
// Struktura/layout/zdjęcia są językowo-neutralne; tu żyje tylko TEKST per locale.
// Publikacja: wszystkie locale wersji idą razem (klonują się z wersją). Fallback → locale domyślny (app).
// `locale` = kod BCP-47 walidowany aplikacyjnie względem BlogLocale.
// ============================================================

model BlogLocale {
  code      String   @id // BCP-47: "pl", "en", "de"
  name      String
  isDefault Boolean  @default(false) // jeden domyślny = fallback (app-enforced)
  enabled   Boolean  @default(true)
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPostVersionTranslation {
  id        String          @id @default(uuid())
  version   BlogPostVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId String
  locale    String

  title       String?
  subtitle    String?
  excerpt     String?
  seoKeywords String[]

  // SEO/meta per locale
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String? // URL różni się per język (hreflang); override gdy treść republikowana

  // liczone przy publikacji (per locale — tekst różni się językowo)
  wordCount      Int?
  readingMinutes Int?

  @@unique([versionId, locale])
  @@index([locale])
}

model BlogSectionTranslation {
  id        String      @id @default(uuid())
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  locale    String

  title    String?
  body     String? // markdown per locale
  keywords String[]

  @@unique([sectionId, locale])
  @@index([locale])
}

model BlogSectionImageTranslation {
  id             String           @id @default(uuid())
  sectionImage   BlogSectionImage @relation(fields: [sectionImageId], references: [id], onDelete: Cascade)
  sectionImageId String
  locale         String

  caption     String?
  alt         String?
  overlayText String?

  @@unique([sectionImageId, locale])
  @@index([locale])
}

model BlogSectionListItemTranslation {
  id     String              @id @default(uuid())
  item   BlogSectionListItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId String
  locale String

  content String?

  @@unique([itemId, locale])
  @@index([locale])
}

model PoiTranslation {
  id     String @id @default(uuid())
  poi    Poi    @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId  String
  locale String

  name        String? // lokalizowany override nazwy (canonical na Poi.name)
  description String?

  @@unique([poiId, locale])
  @@index([locale])
}

model CategoryTranslation {
  id         String   @id @default(uuid())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  locale     String

  label String?

  @@unique([categoryId, locale])
  @@index([locale])
}

model HomeBlockTranslation {
  id      String    @id @default(uuid())
  block   HomeBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId String
  locale  String

  title String?
  body  String?

  @@unique([blockId, locale])
  @@index([locale])
}

// ============================================================
// SEARCH — Postgres FTS. Zdenormalizowany dokument per (post, locale),
// zasilany przy PUBLIKACJI z opublikowanej wersji (drafty nieindeksowane).
// WAŻNE (paywall): indeksujemy TYLKO treść PUBLIC (post accessTier=PUBLIC +
// sekcje minAccessTier=PUBLIC) — inaczej snippet wyciekłby premium niepłacącym.
// searchVector = to_tsvector(regconfig zależny od locale, title+body+keywords),
// utrzymywany raw SQL przy upsert; GIN index dla szybkich zapytań @@ to_tsquery.
// Zapytania: prisma.$queryRaw z ts_rank. Usuwany przy unpublish/archive.
// ============================================================
model BlogSearchDocument {
  id     String   @id @default(uuid())
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  locale String

  // zdenormalizowany tekst z OPUBLIKOWANEJ wersji (per locale)
  title    String?
  excerpt  String?
  body     String? // sklejone body sekcji + listy + caption/alt
  keywords String[]

  searchVector Unsupported("tsvector")?

  updatedAt DateTime @updatedAt

  @@unique([postId, locale])
  @@index([locale])
  @@index([searchVector], type: Gin)
}

// ============================================================
// ACCESS GRANT — przyznanie dostępu, wspólne dla ekosystemu (blog + apka-planer).
// Zakup apki / subskrypcja → przyznany tier (zwykle PREMIUM). Blog gatinguje
// sekcje wg max(aktywne granty, bazowy tier z roli/logowania). Apka wystawia po zakupie.
// ============================================================
model AccessGrant {
  id     String            @id @default(uuid())
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  tier   BlogAccessTier // przyznany poziom (zwykle PREMIUM)
  source AccessGrantSource // APP_PURCHASE / SUBSCRIPTION / MANUAL

  startedAt DateTime  @default(now())
  expiresAt DateTime? // null = bezterminowo
  reference String? // id zakupu / paragonu (store, Stripe itp.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, tier])
  @@index([expiresAt])
}

// Aktywowane urządzenie apki (offline-first). Limit ≤2 aktywne (revokedAt = null) per user.
// Zarządzane z konta na blogu/stronie. Licencja = podpisany token na urządzeniu (offline),
// serwer odnawia online; tu trzymamy tylko metadane + okno ważności do egzekwowania/odwołania.
model AppDevice {
  id               String      @id @default(uuid())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  installationId   String // stabilne per instalacja
  platform         AppPlatform
  name             String?
  activatedAt      DateTime    @default(now())
  lastSeenAt       DateTime?
  revokedAt        DateTime? // null = aktywne (liczy się do limitu 2)
  licenseExpiresAt DateTime? // koniec okna offline; serwer przedłuża online

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, installationId])
  @@index([userId])
}

// Kod do wykorzystania (sprzedaż poza sklepem / prezenty). Wykorzystanie → tworzy AccessGrant.
model RedeemCode {
  id           String         @id @default(uuid())
  code         String         @unique
  tier         BlogAccessTier @default(PREMIUM)
  durationDays Int? // długość dostępu po wykorzystaniu; null = bezterminowo

  redeemedBy   User?     @relation(fields: [redeemedById], references: [id])
  redeemedById String?
  redeemedAt   DateTime?
  expiresAt    DateTime? // do kiedy kod można wykorzystać
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([redeemedById])
}

// ============================================================
// WSPÓŁAUTORSTWO, SERIE, KOLEKCJE „TOP MIEJSC"
// ============================================================

// Byline posta: autorzy i współautorzy (oba mnogie, rola + kolejność). Jeden user = jeden wpis na post.
model BlogPostAuthor {
  id     String         @id @default(uuid())
  post   BlogPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   BlogAuthorRole @default(AUTHOR)
  order  Int            @default(0)

  @@unique([postId, userId])
  @@index([userId])
}

// Seria postów (np. „Islandia cz. 1/2/3"). Tytuł/opis lokalizowane.
model BlogSeries {
  id           String  @id @default(uuid())
  slug         String  @unique
  coverImage   Image?  @relation(fields: [coverImageId], references: [id], onDelete: SetNull)
  coverImageId String?

  posts        BlogPost[]
  translations BlogSeriesTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogSeriesTranslation {
  id       String     @id @default(uuid())
  series   BlogSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  seriesId String
  locale   String

  title       String?
  description String?

  @@unique([seriesId, locale])
  @@index([locale])
}

// Rankowana kolekcja POI: „top miejsca w kolejności" (per kraj/wycieczka/temat).
// Wśród LOVED rozstrzyga ręczny `rank`. Używana w blogu i apce (priorytet).
model PoiCollection {
  id           String  @id @default(uuid())
  slug         String  @unique
  country      String? // opcjonalny scope „top dla kraju"
  region       String?
  isPublic     Boolean @default(true) // publiczna (blog) vs wewnętrzna (planowanie)
  coverImage   Image?  @relation(fields: [coverImageId], references: [id], onDelete: SetNull)
  coverImageId String?

  items        PoiCollectionItem[]
  translations PoiCollectionTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PoiCollectionItem {
  id           String        @id @default(uuid())
  collection   PoiCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  poi          Poi           @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId        String
  rank         Int // 1 = najważniejsze

  @@unique([collectionId, poiId])
  @@index([collectionId, rank])
}

model PoiCollectionTranslation {
  id           String        @id @default(uuid())
  collection   PoiCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  locale       String

  title       String?
  description String?

  @@unique([collectionId, locale])
  @@index([locale])
}
